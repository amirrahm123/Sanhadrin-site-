# Cloudinary Admin API credentials — used ONLY by the /api/gallery serverless
# function to list gallery photos server-side. NEVER exposed to the browser.
#
# In production these are already set in the Vercel project (Production env).
# For local `npm run dev`, copy this file to `.env` (gitignored) and fill in the
# real values. Do NOT commit `.env`.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
